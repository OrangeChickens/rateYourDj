/* pages/dj-edit-pending/dj-edit-pending.wxss - NTS style */

.container {
  min-height: 100vh;
  background-color: #FFFFFF;
  padding: 48rpx 32rpx;
}

.loading, .empty-state {
  padding: 160rpx 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* Request card */
.request-card {
  padding: 32rpx;
  border: 2rpx solid #000;
  margin-bottom: 16rpx;
}

.request-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.dj-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.status-badge {
  padding: 4rpx 16rpx;
  font-size: 18rpx;
  font-weight: 700;
  color: #000;
  border: 2rpx solid #000;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.request-meta {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
}

.load-more {
  text-align: center;
  padding: 48rpx 0;
}

.load-more text {
  padding: 24rpx 64rpx;
  background: #000;
  color: #FFF;
  font-size: 22rpx;
  font-weight: 700;
  border: 2rpx solid #000;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

/* Detail overlay */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-modal {
  width: 90%;
  max-height: 85vh;
  background: #FFF;
  border: 2rpx solid #000;
  display: flex;
  flex-direction: column;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #000;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

.close-btn {
  font-size: 28rpx;
  font-weight: 700;
  color: #000;
  padding: 8rpx 16rpx;
}

.detail-submitter {
  padding: 24rpx 32rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
  border-bottom: 2rpx solid #E0E0E0;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
}

/* Diff section */
.diff-scroll {
  max-height: 50vh;
  padding: 32rpx;
}

.diff-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid #E0E0E0;
}

.diff-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.diff-label {
  width: 100rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 0.5rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.diff-current {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
  word-break: break-all;
}

.diff-arrow {
  font-size: 24rpx;
  color: #000;
  font-weight: 700;
  flex-shrink: 0;
}

.diff-proposed {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
  color: #000;
  word-break: break-all;
}

.diff-proposed.changed {
  font-weight: 700;
  border-bottom: 2rpx solid #000;
}

.bio-text {
  font-size: 22rpx;
  line-height: 1.6;
}

/* Photo diff */
.photo-diff-row {
  flex-direction: column;
}

.photo-compare {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-side {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.diff-photo {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx solid #CCC;
}

.diff-photo.changed {
  border: 2rpx solid #000;
}

.photo-label {
  font-size: 18rpx;
  font-weight: 700;
  color: #666;
  letter-spacing: 0.5rpx;
}

.no-photo {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E0E0E0;
  font-size: 24rpx;
  color: #CCC;
}

/* Action buttons */
.detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  border-top: 2rpx solid #000;
}

.btn-approve {
  flex: 1;
  padding: 28rpx 0;
  background-color: #000;
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  border: 2rpx solid #000;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.btn-reject {
  flex: 1;
  padding: 28rpx 0;
  background-color: #FFF;
  color: #000;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  border: 2rpx solid #000;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}
