<!-- 所有评价页面 -->
<view class="container">
  <!-- Tab 栏 -->
  <view class="tab-bar" wx:if="{{filter === 'moderation'}}">
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" data-tab="pending" bindtap="switchTab">PENDING</view>
    <view class="tab-item {{activeTab === 'reported' ? 'active' : ''}}" data-tab="reported" bindtap="switchTab">REPORTED</view>
    <view class="tab-item {{activeTab === 'approved' ? 'active' : ''}}" data-tab="approved" bindtap="switchTab">APPROVED</view>
    <view class="tab-item {{activeTab === 'rejected' ? 'active' : ''}}" data-tab="rejected" bindtap="switchTab">REJECTED</view>
  </view>

  <view class="reviews-list" wx:if="{{filteredReviews.length > 0}}">
    <view
      wx:for="{{filteredReviews}}"
      wx:key="id"
      class="review-item"
      bindtap="goToDJDetail"
      data-dj-id="{{item.dj_id}}"
      data-review-id="{{item.id}}">

      <view class="review-header">
        <view class="user-info">
          <text class="nickname">{{item.nickname}}</text>
          <text class="time">{{item.timeAgo}}</text>
        </view>
        <view class="rating">
          <text class="rating-number">{{item.overall_rating}}</text>
          <view class="stars">
            <text wx:for="{{item.stars}}" wx:key="index" wx:for-item="star">★</text>
          </view>
        </view>
      </view>

      <!-- 管理员：状态标签 -->
      <view class="review-status-row" wx:if="{{isAdmin}}">
        <text class="status-badge status-{{item.status}}">{{item.status === 'approved' ? 'APPROVED' : item.status === 'rejected' ? 'REJECTED' : 'PENDING'}}</text>
        <text class="report-badge" wx:if="{{item.report_count > 0}}">{{item.report_count}} REPORT{{item.report_count > 1 ? 'S' : ''}}</text>
      </view>

      <view class="dj-info">
        <text class="label">{{texts.djName}}</text>
        <text class="dj-name">{{item.dj_name}}</text>
      </view>

      <view class="review-content" wx:if="{{item.comment}}">
        <text>{{item.comment}}</text>
      </view>

      <!-- 管理员操作按钮 -->
      <view class="action-buttons" wx:if="{{isAdmin}}" catchtap="">
        <view class="btn-approve" wx:if="{{item.status !== 'approved'}}" data-id="{{item.id}}" catchtap="handleApproveReview">APPROVE</view>
        <view class="btn-reject" wx:if="{{item.status !== 'rejected'}}" data-id="{{item.id}}" catchtap="handleRejectReview">REJECT</view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading && currentPage === 1}}">
    <text>{{texts.loading}}</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && filteredReviews.length === 0}}">
    <text class="empty-icon">—</text>
    <text class="empty-text">{{texts.noReviews}}</text>
  </view>

  <!-- 底部加载状态 -->
  <view class="load-more" wx:if="{{filteredReviews.length > 0}}">
    <text wx:if="{{loading}}" class="loading-text">{{texts.loading}}</text>
    <text wx:elif="{{!hasMore}}" class="no-more-text">{{texts.noMore}}</text>
  </view>
</view>
