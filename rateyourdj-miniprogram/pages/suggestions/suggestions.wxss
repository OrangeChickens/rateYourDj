.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  background: #FFF;
  min-height: 100vh;
}

/* 输入区域 */
.input-section {
  border: 2rpx solid #000;
  margin-bottom: 32rpx;
}

.input-area {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder {
  color: #CCC;
  font-weight: 600;
}

.input-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-top: 2rpx solid #E0E0E0;
}

.char-count {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.submit-btn {
  padding: 12rpx 32rpx;
  background: #000;
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.submit-btn.disabled {
  background: #CCC;
}

/* 未登录提示 */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border: 2rpx solid #000;
  margin-bottom: 32rpx;
}

.prompt-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.login-btn {
  padding: 12rpx 32rpx;
  background: #000;
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* 建议列表 */
.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.suggestion-card {
  padding: 32rpx 0;
  border-bottom: 2rpx solid #E0E0E0;
}

.suggestion-card:first-child {
  padding-top: 0;
}

.card-content {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.6;
  color: #000;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meta-author {
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  text-transform: uppercase;
}

.meta-dot {
  margin: 0 8rpx;
  color: #CCC;
  font-weight: 700;
}

.meta-time {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
}

.meta-status {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  text-transform: uppercase;
}

.status-planned {
  color: #000;
}

.status-done {
  color: #666;
}

.status-rejected {
  color: #CCC;
}

/* 投票按钮 */
.card-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.vote-btn {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border: 2rpx solid #000;
  gap: 8rpx;
}

.vote-btn.active {
  background: #000;
  color: #FFF;
}

.vote-icon {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.vote-count {
  font-size: 24rpx;
  font-weight: 700;
}

.delete-btn {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 700;
  color: #666;
  letter-spacing: 0.5rpx;
  padding: 8rpx 16rpx;
  border: 2rpx solid #CCC;
}

/* 空状态 */
.empty-state {
  padding: 128rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #CCC;
}

/* 加载中 */
.loading-state {
  padding: 64rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 24rpx;
  font-weight: 700;
  color: #CCC;
  letter-spacing: 1rpx;
}

/* 没有更多 */
.no-more {
  padding: 48rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #CCC;
  letter-spacing: 1rpx;
}
